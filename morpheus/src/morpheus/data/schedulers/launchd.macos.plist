<?xml version="1.0" encoding="UTF-8"?>
<!--
  Optional reconciliation sweep for macOS (launchd).
  Requires: pip install morpheus-dreaming

  1. Set the python path below if `python` isn't on launchd's PATH.
  2. Copy to ~/Library/LaunchAgents/com.ceryce.claude-morpheus.plist
  3. launchctl load ~/Library/LaunchAgents/com.ceryce.claude-morpheus.plist

  Runs every 1800 seconds (30 min). The hooks already dream on compaction/end;
  this only catches crashed/archived sessions.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ceryce.claude-morpheus</string>
  <key>ProgramArguments</key>
  <array>
    <string>python</string>
    <string>-m</string>
    <string>morpheus</string>
    <string>reconcile</string>
  </array>
  <key>StartInterval</key>
  <integer>1800</integer>
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
