{
  "hooks": {
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "\"<PY>\" \"<DISPATCH>\"", "timeout": 30 }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "\"<PY>\" \"<DISPATCH>\"", "timeout": 30 }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          { "type": "command", "command": "\"<PY>\" \"<DISPATCH>\"", "timeout": 20 }
        ]
      }
    ]
  }
}
