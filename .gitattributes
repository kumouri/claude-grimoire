# Normalize line endings: text files store as LF in the repo.
* text=auto eol=lf

# Scripts must stay LF even on Windows checkouts.
*.py   text eol=lf
*.sh   text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Windows-only helper keeps CRLF.
*.ps1  text eol=crlf
